@model Product 
@{
    ViewData["Title"] = "CreateProduct";
    Layout = "~/Views/AdminLayout/Index.cshtml";

}


<section class="content">
    <div class="block-header">
        <div class="row">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    Create Product 
                    <small class="text-muted">Product Operations List</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="index.html"><i class="zmdi zmdi-home"></i> Product</a></li>
                    <li class="breadcrumb-item"><a href="javascript:void(0);">Product List</a></li>
                    <li class="breadcrumb-item active">Main Page</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="body">

                        <form method="post">
                            <label>Product Name</label>
                            <input type="text" asp-for="ProductName" class="form-control" />
                            </br>
                            <label>Product Description</label>
                            <input type="text" asp-for="ProductDescription" class="form-control" />
                            </br>
                            <label>Unit Price /€</label>
                            <input type="text" asp-for="UnitPrice" class="form-control" />
                            </br>
                            <label>Product Stock</label>
                            <input type="text" asp-for="StockQuantity" class="form-control" />
                            </br>
                            <label>Product Category</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-control show-tick">
                                <option value="">--Select Category--</option>
                            </select>
                            </br>
                            <label>Origin Country</label>
                            <input type="text" asp-for="CountryOfOrigin" class="form-control " />
                            </br>
                            <label>Product Image(URL)</label>
                            <input type="text" asp-for="ProductImageUrl" class="form-control" />
                            </br>
                            <button class="btn btn-info">Create The Product</button>
                        </form>



                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
   


