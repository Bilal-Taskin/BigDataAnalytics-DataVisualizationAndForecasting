@model List<Product>

<div class="col-lg-4 col-md-6 col-sm-12">
    <div class="card activities">
        <div class="header">
            <h2>Products with critical stock levels</h2>
           
        </div>
       
        <div class="body" style="height: 550px; overflow-y: auto;">
            <div class="streamline b-l b-accent">
                @foreach (var item in Model)
                {
                    <div class="sl-item b-primary b-l">
                        <div class="sl-content">
                            <div class="text-muted-dk">@item.ProductName: @item.StockQuantity pieces</div>
                            <p><a href="" class="text-info"></a></p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>