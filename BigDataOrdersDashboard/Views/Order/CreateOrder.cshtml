@model Order
@{
    ViewData["Title"] = "CreateOrder";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="content">
    <div class="block-header">
        <div class="row">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    Create Order
                    <small class="text-muted">Order Operations List</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="index.html"><i class="zmdi zmdi-home"></i> Order</a></li>
                    <li class="breadcrumb-item"><a href="javascript:void(0);">Order List</a></li>
                    <li class="breadcrumb-item active">Main Page</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">  
                    <div class="body">

                        <form method="post">
                            <label>Product Id</label>
                            <input type="text" asp-for="ProductId" class="form-control" />
                            </br>
                            <label>Customer Id</label>
                            <input type="text" asp-for="CustomerId" class="form-control" />
                            </br>
                            <label>Quantity /€</label>
                            <input type="text" asp-for="Quantity" class="form-control" />
                            </br>
                            <label>Payment Method </label>
                            <select asp-for="PaymentMethod" class="form-control show-tick">
                                <option value="">-- Select Payment Method  --</option>
                                <option value="Kredi Kartı">Kredi Kartı</option>
                                <option value="Google Pay">Google Pay</option>
                                <option value="Banka Kartı">Banka Kartı</option>
                                <option value="PayPal">PayPal</option>
                                <option value="Havale/Eft">Havale/Eft</option>
                            </select>
                            </br>
                            <label>Order Status</label>
                            <select asp-for="OrderStatus" class="form-control show-tick" required>
                                <option value="">-- Select Order Status --</option>
                                <option value="İptal Edildi">İptal Edildi</option>
                                <option value="Tamamlandı">Tamamlandı</option>
                                <option value="Hazırlanıyor">Hazırlanıyor</option>
                                <option value="Kargoda">Kargoda</option>
                                <option value="Beklemede">Beklemede</option>
                            </select>
                            </br>
                            <label>Order Notes</label>
                            <input type="text" asp-for="OrderNotes" class="form-control " />
                            </br>
                           
                            <button class="btn btn-info">Create The Order</button>
                        </form>



                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

