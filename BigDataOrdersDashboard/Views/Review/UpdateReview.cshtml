@model Review
@{
    ViewData["Title"] = "CreateReview";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="content">
    <div class="block-header">
        <div class="row">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    Update Review
                    <small class="text-muted">Review Operations List</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="index.html"><i class="zmdi zmdi-home"></i> Review</a></li>
                    <li class="breadcrumb-item"><a href="javascript:void(0);">Review List</a></li>
                    <li class="breadcrumb-item active">Main Page</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="body">

                        <form method="post">

                            <input type="hidden" asp-for="ReviewId" />
                            <label>Customer Id</label>
                            <input type="text" asp-for="CustomerId" class="form-control" />
                            </br>

                            <label>Product Id</label>
                            <input type="text" asp-for="ProductId" class="form-control" />
                            </br>

                            <label>Purchase Type</label>
                            <input type="text" asp-for="PurchaseType" class="form-control" />
                            </br>

                            <label>Rate</label>
                            <input type="text" asp-for="Rating" class="form-control" />
                            </br>

                            <label>Review Analyze</label>
                            <input type="text" asp-for="ReviewText" class="form-control" />
                            </br>

                            <label>Emotion Analyze</label>
                            <input type="text" asp-for="Sentiment" class="form-control" />
                            </br>



                            <button class="btn btn-success">Update The Review</button>
                        </form>



                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

